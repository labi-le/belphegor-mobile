<?xml version="1.0" encoding="utf-8"?>
<!-- Apple-HIG skin over Material3 (DESIGN.md). Light: gray grouped canvas,
     white cards, systemBlue accent. Surface roles map to the iOS background
     ramp so every Material component (dialogs, fields, menus) lands on it. -->
<resources>
    <style name="Theme.Belphegor" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="colorPrimaryContainer">@color/accent</item>
        <item name="colorOnPrimaryContainer">#FFFFFFFF</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryContainer">@color/accent_container</item>
        <item name="colorOnSecondaryContainer">@color/on_accent_container</item>
        <item name="colorError">@color/ios_red</item>
        <!-- Platform widgets (EditText cursor/handles, ProgressBar) tint via
             colorControlActivated -> colorAccent -> colorSecondary; pin it to
             the accent so no M3 baseline purple leaks through. -->
        <item name="colorControlActivated">@color/accent</item>
        <!-- M3 maps text selection to colorOnPrimaryContainer (white here) —
             restate it as a visible accent wash on both themes. -->
        <item name="android:textColorHighlight">@color/selection_highlight</item>

        <item name="android:colorBackground">@color/bg_canvas</item>
        <item name="android:windowBackground">@color/bg_canvas</item>
        <item name="colorSurface">@color/bg_canvas</item>
        <item name="colorSurfaceDim">@color/bg_canvas</item>
        <item name="colorSurfaceBright">@color/bg_card</item>
        <item name="colorSurfaceContainerLowest">@color/bg_card</item>
        <item name="colorSurfaceContainerLow">@color/bg_card</item>
        <item name="colorSurfaceContainer">@color/bg_card</item>
        <item name="colorSurfaceContainerHigh">@color/bg_dialog</item>
        <item name="colorSurfaceContainerHighest">@color/bg_field</item>
        <item name="colorSurfaceVariant">@color/bg_field</item>
        <item name="colorOnSurface">@color/label</item>
        <item name="colorOnSurfaceVariant">@color/label_secondary</item>
        <item name="colorOutline">@color/separator</item>
        <item name="colorOutlineVariant">@color/separator</item>

        <item name="android:statusBarColor">@color/bg_canvas</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bg_canvas</item>
        <!-- API 27+ honors this; API 26 ignores unknown style attrs. -->
        <item name="android:windowLightNavigationBar">true</item>
        <item name="actionMenuTextColor">@color/accent</item>
        <item name="actionMenuTextAppearance">@style/TextAppearance.Belphegor.MenuAction</item>
        <item name="bottomNavigationStyle">@style/Widget.Belphegor.BottomNav</item>
        <item name="shapeAppearanceCornerExtraLarge">@style/ShapeAppearance.Belphegor.Dialog</item>
    </style>

    <!-- Toolbar text actions: iOS plain buttons — Title-Case, not ALL CAPS. -->
    <style name="TextAppearance.Belphegor.MenuAction" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">17sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- iOS alert chrome: ~14pt corners. Title is centered via setCustomTitle
         in code (M3 keeps alertTitle wrap_content, so a style gravity can't). -->
    <style name="ShapeAppearance.Belphegor.Dialog" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerSize">14dp</item>
    </style>

    <!-- iOS tab bar out of an M3 BottomNavigationView: no indicator pill
         (disabled in code), flat canvas bg, same-size label in both states
         so selection changes color only. -->
    <style name="Widget.Belphegor.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bg_canvas</item>
        <item name="itemIconTint">@color/tab_item</item>
        <item name="itemTextColor">@color/tab_item</item>
        <item name="itemPaddingTop">8dp</item>
        <item name="itemPaddingBottom">10dp</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.Belphegor.TabLabel</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.Belphegor.TabLabel</item>
    </style>

    <style name="TextAppearance.Belphegor.TabLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Inline nav title: 17 medium, centered (set on the MaterialToolbar). -->
    <style name="TextAppearance.Belphegor.ToolbarTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">17sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
